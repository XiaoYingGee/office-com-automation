{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://office-com-automation/spec/capabilities/schema/op-request.schema.json",
  "title": "OpRequest",
  "description": "A single stateless capability invocation request.",
  "type": "object",
  "required": ["op", "path"],
  "additionalProperties": false,
  "properties": {
    "op": {
      "type": "string",
      "description": "Dotted operation name, e.g. 'cell.write', 'range.read', 'batch.apply'."
    },
    "path": {
      "type": "string",
      "description": "Absolute or relative path to the target workbook."
    },
    "target": {
      "type": "object",
      "description": "Optional sheet/range address within the workbook.",
      "additionalProperties": false,
      "properties": {
        "sheet": { "type": "string", "description": "Worksheet name." },
        "range": { "type": "string", "description": "A1-notation range, e.g. 'A1', 'A1:C10'." }
      }
    },
    "params": {
      "type": "object",
      "description": "Operation-specific parameters. Schema varies by op.",
      "default": {}
    },
    "save_as": {
      "type": "object",
      "description": "If present, save the workbook to this path/format after the operation.",
      "required": ["path", "format"],
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string" },
        "format": {
          "type": "string",
          "enum": ["xlsx", "xlsm", "xls", "csv"],
          "description": "Output format."
        }
      }
    }
  }
}
