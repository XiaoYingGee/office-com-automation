{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://office-com-automation/spec/capabilities/schema/capability.schema.json",
  "title": "Capability",
  "description": "Describes a single testable Excel capability entry in the catalog.",
  "type": "object",
  "required": ["id", "name", "desc", "op", "sample", "verify", "support"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Short unique slug, e.g. 'cell.write'."
    },
    "name": {
      "type": "string",
      "description": "Human-readable capability name."
    },
    "desc": {
      "type": "string",
      "description": "One-sentence description of what this capability does."
    },
    "op": {
      "type": "string",
      "description": "The OpRequest.op string that invokes this capability."
    },
    "param_path": {
      "type": "string",
      "description": "JSON pointer into params object for the primary parameter (optional)."
    },
    "sample": {
      "type": "object",
      "description": "A complete example OpRequest payload (without op/path).",
      "properties": {
        "target": { "type": "object" },
        "params": { "type": "object" },
        "save_as": { "type": "object" }
      }
    },
    "verify": {
      "type": "object",
      "description": "Verification recipe: write then read-back and assert.",
      "required": ["action", "assert"],
      "additionalProperties": false,
      "properties": {
        "action": {
          "type": "object",
          "description": "The OpRequest params/target to execute as the write step.",
          "required": ["op"],
          "additionalProperties": false,
          "properties": {
            "op": { "type": "string" },
            "params": { "type": "object" },
            "target": {
              "type": "object",
              "description": "Optional target location (sheet/range) for the write step.",
              "properties": {
                "sheet": { "type": "string" },
                "range": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        },
        "reopen": {
          "type": "boolean",
          "description": "If true, close and reopen the workbook before asserting.",
          "default": false
        },
        "assert": {
          "type": "object",
          "description": "Read-back assertion.",
          "required": ["read"],
          "additionalProperties": false,
          "properties": {
            "read": {
              "type": "string",
              "description": "Op to execute for reading back the value."
            },
            "expect": {
              "description": "Expected value (any JSON scalar or object)."
            },
            "tol": {
              "type": "number",
              "description": "Floating-point tolerance for numeric comparisons."
            }
          }
        }
      }
    },
    "errors": {
      "type": "array",
      "description": "Error categories this capability may return.",
      "items": {
        "type": "string",
        "enum": [
          "FileNotFound",
          "FileLocked",
          "InvalidArg",
          "RangeParseError",
          "SheetNotFound",
          "UnsupportedFormat",
          "ComError",
          "MacroTrustDisabled",
          "Timeout",
          "Unknown"
        ]
      }
    },
    "com_ref": {
      "type": "string",
      "description": "Reference to the Excel COM object/method (e.g. 'Range.Value2')."
    },
    "support": {
      "type": "object",
      "description": "Implementation support status per language.",
      "required": ["vba", "cpp", "rust", "openxml"],
      "additionalProperties": false,
      "properties": {
        "vba":     { "$ref": "#/$defs/supportStatus" },
        "cpp":     { "$ref": "#/$defs/supportStatus" },
        "rust":    { "$ref": "#/$defs/supportStatus" },
        "openxml": { "$ref": "#/$defs/supportStatus" }
      }
    }
  },
  "$defs": {
    "supportStatus": {
      "type": "string",
      "enum": ["✅", "⚠️", "❌", "⬜"],
      "description": "✅=implemented, ⚠️=partial/workaround, ❌=not possible, ⬜=not yet attempted"
    }
  }
}
